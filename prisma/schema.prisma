generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL is configured in prisma.config.ts
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  clients          Client[]
  services         Service[]
  financialEntries FinancialEntry[]
  receipts         Receipt[]

  @@map("users")
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamento com User (MEI)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relacionamento com lançamentos financeiros
  financialEntries FinancialEntry[]

  @@map("clients")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacionamento com User (MEI)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relacionamento com lançamentos financeiros
  financialEntries FinancialEntry[]

  @@map("services")
}

model FinancialEntry {
  id            String   @id @default(uuid())
  type          String // "income" ou "expense"
  amount        Decimal
  description   String
  date          DateTime
  paymentMethod String? // "pix", "cartao", "dinheiro", "boleto", "transferencia"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamento com User (MEI)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relacionamento opcional com Cliente
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // Relacionamento opcional com Serviço
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])
  receipt   Receipt?

  @@map("financial_entries")
}

model Receipt {
  id            String    @id @default(uuid())
  number        String    @unique // Número do recibo (ex: REC-0001)
  amount        Decimal
  description   String
  date          DateTime
  clientId      String?
  clientName    String?
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  issuerName    String?
  issuerEmail   String?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  pdfUrl        String?
  shareUrl      String    @unique
  isPublic      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamento com User (MEI)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relacionamento com lançamento financeiro (opcional)
  financialEntryId String?         @unique
  financialEntry   FinancialEntry? @relation(fields: [financialEntryId], references: [id])

  @@map("receipts")
}
